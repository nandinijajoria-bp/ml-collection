<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<springProfile name="dev">
		<property name="LOG.APPENDER" value="Console" />
        <property name="SENTRY.APPENDER.LEVEL" value="OFF" />
		<property name="LOG.FILE" value="logs/lending-java.log" />
	</springProfile>
	
	<springProfile name="!dev">
		<property name="LOG.APPENDER" value="Console" />
        <property name="SENTRY.APPENDER.LEVEL" value="ERROR" />
		<property name="LOG.FILE" value="/Users/yogenderyadav/bp_workspace/lending-logs/lending-java.log" />
	</springProfile>
	
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>%d{dd-MM-yyyy HH:mm:ss.SSS} %magenta([%thread]) [%X] %highlight(%-5level) %logger{36}.%M\(%line\) - %msg%n</pattern>
        </layout>
    </appender>
 
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG.FILE}</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{dd-MM-yyyy HH:mm:ss.SSS} %magenta([%thread]) [%X] %highlight(%-5level) %logger{36}.%M\(%line\) - %msg%n</pattern>
        </encoder>
 
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">        
        <fileNamePattern>${LOG.FILE}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
        <maxHistory>30</maxHistory>
    </rollingPolicy>
    </appender>

    <appender name="Sentry" class="io.sentry.logback.SentryAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${SENTRY.APPENDER.LEVEL}</level>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{dd-MM-yyyy HH:mm:ss.SSS} [%thread] [%X] %-5level %logger{36}.%M\(%line\) - %msg%n</pattern>
        </encoder>
    </appender>
     
    <logger name="com.bharatpe" level="INFO"></logger>
    <logger name="com.zaxxer.hikari.pool.HikariPool" level="DEBUG"/>

    <root level="ERROR">
        <appender-ref ref="${LOG.APPENDER}"/>
        <appender-ref ref="Sentry"/>
    </root>
</configuration>
